msgid ""
"bootnet crashed with the following error message:\n"
"%s"
msgstr ""
"bootnet mogok dengan pesan galat berikut:\n"
"%s"

msgid ""
"Please drag all variables to a particular type under \"Analysis options\"."
msgstr ""
"Silakan seretkan semua variabel ke jenis tertentu di bawah \"Opsi analisis\"."

msgid ""
"Coefficient could not be standardized because the variance is too small."
msgstr "Koefisien tidak dapat distandardisasi karena varians terlalu kecil."

msgid "Please supply a name for both the x and y-coordinates of the layout."
msgstr "Silakan sediakan nama untuk kedua koordinat-x dan y dari tata letak."

msgid "Some variables did not contain char (%s)"
msgstr "Beberapa variabel tidak berisi kar (%s)"

msgid "Some variables were not matched in the column names of the dataset."
msgstr "Beberapa variabel tidak cocok di nama kolom dari rangkaian data."

msgid ""
"Supplied data for layout was not understood and instead a circle layout was "
"used."
msgstr ""
"Data disediakan untuk tata letak tidak dipahami dan sebagai pengganti tata "
"letak lingkaran telah digunakan."

msgid ""
"Data supplied in %1$s AND %2$s could not be used to determine node locations."
msgstr ""
"Data disediakan di %1$s AND %2$s tidak dapat digunakan untuk menentukan "
"lokasi simpul."

msgid "Data supplied in %s could not be used to determine node locations."
msgstr ""
"Data disediakan di %s tidak dapat digunakan untuk menentukan lokasi simpul."

msgid ""
"%1$s %2$s Data should only contain numeric:\n"
"                 -start with the column name of the variable.\n"
"                 -contain an '=' to distinguish between column name and "
"coordinate."
msgstr ""
"%1$s %2$s Data hanya harus berisi numerik:\n"
"                 -mulai dengan nama kolom dari variabel.\n"
"                 -berisi '=' untuk membedakan antara nama dan koordinat "
"kolom."

msgid ""
"bootnet crashed with the following error message:\n"
"%s. <ul><li>Please check if there are variables in the network with little "
"variance or few distinct observations.</li></ul>"
msgstr ""
"bootnet mogok dengan pesan galat berikut:\n"
"%s. <ul><li>Silakan periksa jika ada variabel di jaringan dengan variabel "
"kecil atau sedikit observasi berbeda.</li></ul>"

msgid "%1$s X-Coordinates for variable %2$s was not understood."
