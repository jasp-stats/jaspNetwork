msgid ""
"%1$s %2$s Data should only contain numeric:\n"
"                 -start with the column name of the variable.\n"
"                 -contain an '=' to distinguish between column name and "
"coordinate."
msgstr ""
"%1$s %2$s Os datos deben ser só números:\n"
"                 - Comezar co nome de columna da variable.\n"
"                 - Conter un '=' para distinguir entre o nome de columna e a "
"coordenada."

msgid ""
"bootnet crashed with the following error message:\n"
"%s. <ul><li>Please check if there are variables in the network with little "
"variance or few distinct observations.</li></ul>"
msgstr ""
"bootnet rachou coa seguinte mensaxe de fallo:\n"
"%s. <ul><li>Por favor, comproba se hai variables na rede con varianza "
"pequena ou con poucas observacións distintas.</li></ul>"

